    "axios": "^1.11.0",
    "concurrently": "^9.0.1",
    "husky": "^9.1.7",
    "laravel-echo": "^1.16.1",
    "laravel-vite-plugin": "^2.0.0",
    "lint-staged": "^16.4.0",
    "popper.js": "^1.12",
    "postcss": "^8.5.6",
    "postcss-nesting": "^13.0.2",
    "prettier": "^3.0.3",
    "prettier-plugin-tailwindcss": "^0.5.7",
    "pusher-js": "^8.4.0",
    "tailwindcss": "^4.1.11",
    "vite": "^7.0.7"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.13.2",
