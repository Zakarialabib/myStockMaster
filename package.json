    "alpinejs": "^3.5.0",
    "apexcharts": "^3.44.0",
    "flatpickr": "^4.6.13",
    "perfect-scrollbar": "^1.5.5",
    "sortablejs": "^1.15.0",
    "sweetalert2": "^11.26.24",
    "trix": "^2.1.17",
    "vitepress": "^1.6.4",
    "vue": "^3.3.8"
  }
